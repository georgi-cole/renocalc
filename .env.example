# =============================================================================
# ICO Renovation Reporting App – Environment Variables Example
# =============================================================================
# This file documents the environment variables used by the app.
# Copy this file to .env.local (or .env) and fill in your values.
# NEVER commit .env or .env.local to source control – they contain secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase credentials
# ---------------------------------------------------------------------------
# Get these from your Supabase project dashboard:
#   Settings → API → Project URL  and  Settings → API → anon (public) key
#
# If this is a plain static site (no build step / Vite), set these values
# directly in assets/js/config.js on your local machine and ensure that file
# is listed in .gitignore so real keys are never pushed to the repository.
#
# If you add a Vite / webpack build step later, replace the values in
# config.js with:
#   SUPABASE_URL:      import.meta.env.VITE_SUPABASE_URL,
#   SUPABASE_ANON_KEY: import.meta.env.VITE_SUPABASE_ANON_KEY,
# and then the variables below will be picked up automatically.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
